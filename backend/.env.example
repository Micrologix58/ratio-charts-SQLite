# Copy this file to .env and fill in real values. .env is gitignored -- never commit real secrets.

# Path to the SQLite database file. Defaults to ../data/CommoditiesStockAnalysis.db if unset.
SQLITE_DB_PATH=

# marketdata.app (used by 1-update_prices.py and 4-update_prices_manual.py)
MARKETDATA_API_KEY=

# api.massive.com (used by treasury, forex/macro, futures, and index scripts)
MASSIVE_API_KEY=

# Optional tuning (defaults shown are what the scripts fall back to)
TICKERS_FILE=tickers.txt
PRICE_UPDATE_LOG_DIR=logs
BASE_OVERLAP_DAYS=7
SAFETY_DAYS=3
MAX_OVERLAP_DAYS=60
BATCH_SIZE=5
BATCH_DELAY_SECONDS=20
REQUEST_TIMEOUT=30
MAX_RETRIES=4
FUTURES_WATCHLIST_FILE=futures_watchlist.csv
INDEX_WATCHLIST_FILE=indexes.csv
